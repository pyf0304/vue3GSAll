        switch (strViewsTabNum) {
          case '1':
            $('#ArrangeClassificationTitle1').html('当前分类：' + strClassificationName);
            break;
          case '2':
            $('#ArrangeClassificationTitle2').html('当前分类：' + strClassificationName);
            break;
          case '3':
