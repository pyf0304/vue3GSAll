      function GetPropValue(strPropName: string): string {
        switch (strPropName) {
          case 'idCurrEduCls':
            return idCurrEduCls.value;
          case 'topicId':
            return topicId.value;
          case 'activeTabId':
            return activeTabId.value;
          case 'classificationId':
            return classificationId.value;
          case 'viewsId':
            return viewsId.value;
          default:
            return '';
