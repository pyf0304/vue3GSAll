            */
  function UpdateRecord() {
    require([
      '../js/GraduateEduTopic/ResearchTopic_QUDIEx.js',
      '../js/TS/PubFun/clsCommonFunc4Web.js',
    ], function (researchtopic, commonfunc) {
      var strKeyId = commonfunc.clsCommonFunc4Web.GetFirstCheckedKeyId('divList');
      if (strKeyId == '') {
        alert('请选择需要修改的记录！');
        return;
      }
      ShowDialog('Update');
      var objPage = new researchtopic.ResearchTopic_QUDIEx();
      objPage.ShowData(strKeyId);
      return true;
    });
  }

