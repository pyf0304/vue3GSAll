  //修改主题用户色码块；
  public btnUpdateUserRelaInTab0_Click(strKeyId: string, strRoleId: string) {
    if (strKeyId == '') {
      alert('请选择需要删除的记录！');
      return;
    }

    $('#hidTopicUserId').val(strKeyId);
    const objPage = new ResearchTopic_QUDIEx();
    objPage.btnUpdateUserRelaInTab_Click(strKeyId, strRoleId);
