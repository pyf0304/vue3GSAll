<input id="hidSortvqa_PaperBy" type="hidden" value="" />

@*//类型用于区分是查看的还是个人维护的*@
<input id="hidTypeId" type="hidden" />

@*//类型用于区分是查看的还是个人维护的*@
<input id="hidIsReceive" type="hidden" />

@* 被邀请数 *@
<input id="hidQuestionsCount" type="hidden" />
