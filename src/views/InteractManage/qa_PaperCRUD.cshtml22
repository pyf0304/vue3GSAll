            <ul class="nav">
                <li class="nav-item">
                    <Label id="lblqa_PaperList" name="lblqa_PaperList" class="col-form-label text-info" style="width:250px;">
                        论文答疑列表
                    </Label>
                </li>
                <li class="nav-item ml-3">

                </li>
                <li class="nav-item ml-3">
                        <button id="btnUpdateRecord" name="btnUpdateRecord" class="btn btn-outline-info btn-sm text-nowrap" onclick="btn_Click('Update')">修改</button>
                    </li>
                <li class="nav-item ml-3">

                </li>
            </ul>
        </div>*@
    @*-- 列表层 --*@

    <div class="layui-collapse" lay-accordion>
        <div class="layui-colla-item">
            <h2 class="layui-colla-title">论文答疑列表</h2>
            <div id="divtab1" class="layui-colla-content layui-show">


                @*<div class="btn-group btn-group-sm">
                        <button class="btn btn-success" id="btnAddNewRecord" name="btnAddNewRecord" onclick="btn_Click('AddNewRecordWithMaxId')"><i class="layui-icon">&#xe654;</i>添加答疑</button>
                        <button class="btn btn-danger" id="btnDelRecord" style="display:none;" name="btnDelRecord" onclick="btn_Click('Delete')"><i class="layui-icon">&#xe640;</i>删除答疑</button>
                    </div>*@
                <div id="divList" class="div_List">
                    <div id="divDataLst" class="div_List">
                    </div>
